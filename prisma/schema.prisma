generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ══════════════════════════════════════════════════════════════════
// Core User Model
// ══════════════════════════════════════════════════════════════════

model User {
  id              String            @id @default(cuid())
  name            String
  email           String            @unique
  passwordHash    String
  role            String            @default("user")
  avatar          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rewardAccounts  RewardAccount[]
  recommendations Recommendation[]
  agentExecutions AgentExecution[]
  cardReports     CardReport[]
  userCards       UserCard[]
  userRewards     UserReward[]
}

// ══════════════════════════════════════════════════════════════════
// Normalized Knowledge Graph (Phase 1)
// ══════════════════════════════════════════════════════════════════

model Bank {
  id          String       @id @default(cuid())
  name        String
  code        String       @unique
  website     String?
  logoUrl     String?
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  cards       Card[]
  sourcePages SourcePage[]
}

model Card {
  id                   String            @id @default(cuid())
  bankId               String
  name                 String
  network              String
  cardType             String            @default("credit")
  tier                 String?
  annualFee            Float             @default(0)
  joiningFee           Float             @default(0)
  imageUrl             String?
  color                String?
  bestFor              String?
  worstFor             String?
  estimatedAnnualValue Float             @default(0)
  isActive             Boolean           @default(true)
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt
  bank                 Bank              @relation(fields: [bankId], references: [id])
  benefits             Benefit[]
  rewardPrograms       NormalizedProgram[]
  offers               Offer[]
  bins                 CardBIN2[]
  sourcePages          SourcePage[]
  userCards2           UserCard[]        @relation("UserCardToCard")
}

model Benefit {
  id            String   @id @default(cuid())
  cardId        String
  category      String
  title         String
  description   String
  terms         String?
  valueEstimate Float    @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  card          Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model NormalizedProgram {
  id              String             @id @default(cuid())
  cardId          String
  name            String
  pointName       String
  earnRate        String
  earnDescription String?
  expiryMonths    Int?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  card            Card               @relation(fields: [cardId], references: [id], onDelete: Cascade)
  redemptions     RedemptionOption[]
  transferPartners TransferPartner[]
  userRewards     UserReward[]
}

model RedemptionOption {
  id             String            @id @default(cuid())
  programId      String
  name           String
  type           String
  conversionRate Float
  minPoints      Float             @default(0)
  description    String?
  estimatedCPP   Float             @default(0)
  isActive       Boolean           @default(true)
  createdAt      DateTime          @default(now())
  program        NormalizedProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model TransferPartner {
  id            String            @id @default(cuid())
  programId     String
  partnerName   String
  partnerType   String
  transferRatio String
  transferFee   Float             @default(0)
  transferTime  String?
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  program       NormalizedProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model Offer {
  id            String    @id @default(cuid())
  cardId        String
  title         String
  description   String?
  merchant      String?
  discountType  String?
  discountValue String?
  validFrom     DateTime?
  validTo       DateTime?
  terms         String?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  card          Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model CardBIN2 {
  id       String  @id @default(cuid())
  bin      String  @unique
  cardId   String
  tier     String?
  country  String  @default("IN")
  card     Card    @relation(fields: [cardId], references: [id])
}

model UserReward {
  id          String             @id @default(cuid())
  userId      String
  programId   String
  balance     Float              @default(0)
  lastSynced  DateTime           @default(now())
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  program     NormalizedProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([userId, programId])
}

// ══════════════════════════════════════════════════════════════════
// Data Acquisition + Extraction Pipeline
// ══════════════════════════════════════════════════════════════════

model SourcePage {
  id            String          @id @default(cuid())
  url           String          @unique
  bankId        String?
  cardId        String?
  pageType      String          @default("card_page")
  lastCrawledAt DateTime?
  contentHash   String?
  status        String          @default("pending")
  rawContent    String?
  extractedAt   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  bank          Bank?           @relation(fields: [bankId], references: [id])
  card          Card?           @relation(fields: [cardId], references: [id])
  crawlJobs     CrawlJob[]
  extractionJobs ExtractionJob[]
}

model CrawlJob {
  id           String          @id @default(cuid())
  sourcePageId String
  status       String          @default("queued")
  method       String
  startedAt    DateTime?
  completedAt  DateTime?
  error        String?
  durationMs   Int?
  createdAt    DateTime        @default(now())
  sourcePage   SourcePage      @relation(fields: [sourcePageId], references: [id], onDelete: Cascade)
  extractionJobs ExtractionJob[]
}

model ExtractionJob {
  id               String     @id @default(cuid())
  sourcePageId     String
  crawlJobId       String?
  status           String     @default("pending")
  model            String?
  promptTokens     Int?
  completionTokens Int?
  extractedData    String?
  validationErrors String?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime   @default(now())
  sourcePage       SourcePage @relation(fields: [sourcePageId], references: [id], onDelete: Cascade)
  crawlJob         CrawlJob?  @relation(fields: [crawlJobId], references: [id])
}

// ══════════════════════════════════════════════════════════════════
// Legacy Models (kept for backward compatibility)
// ══════════════════════════════════════════════════════════════════

model CardBIN {
  id            String       @id @default(cuid())
  bin           String       @unique
  bank          String
  network       String
  type          String
  tier          String?
  country       String       @default("IN")
  cardProductId String?
  cardProduct   CardProduct? @relation(fields: [cardProductId], references: [id])
}

model CardProduct {
  id                   String       @id @default(cuid())
  name                 String
  bank                 String
  network              String
  cardType             String       @default("credit")
  color                String?
  imageUrl             String?
  annualFee            Float        @default(0)
  joiningFee           Float        @default(0)
  rewardStructure      String?
  cashbackStructure    String?
  loungeAccess         String?
  travelBenefits       String?
  insuranceBenefits    String?
  fuelBenefits         String?
  diningBenefits       String?
  movieBenefits        String?
  golfBenefits         String?
  forexMarkup          String?
  milestoneRewards     String?
  welcomeBenefits      String?
  currentOffers        String?
  bestFor              String?
  worstFor             String?
  estimatedAnnualValue Float        @default(0)
  isActive             Boolean      @default(true)
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  bins                 CardBIN[]
  reports              CardReport[]
  userCardsLegacy      UserCard[]
}

model CardReport {
  id            String      @id @default(cuid())
  userId        String
  cardProductId String
  inputBIN      String?
  aiSummary     String?
  createdAt     DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardProduct   CardProduct @relation(fields: [cardProductId], references: [id], onDelete: Cascade)
}

model UserCard {
  id              String             @id @default(cuid())
  userId          String
  cardProductId   String?
  cardId          String?
  inputBIN        String
  last4           String?
  nickname        String?
  bank            String?
  network         String?
  cardType        String?
  tier            String?
  country         String?
  productName     String?
  confidence      String             @default("unknown")
  confidenceScore Float              @default(0)
  matchSource     String?
  rewardProgramId String?
  rewardProgram   RewardProgram?     @relation(fields: [rewardProgramId], references: [id])
  pipelineLog     String?
  isActive        Boolean            @default(true)
  onboardedAt     DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardProduct     CardProduct?       @relation(fields: [cardProductId], references: [id])
  normalizedCard  Card?              @relation("UserCardToCard", fields: [cardId], references: [id])

  @@unique([userId, inputBIN])
}

model RewardProgram {
  id                 String           @id @default(cuid())
  name               String
  provider           String
  type               String
  conversionRate     Float
  currencyEquivalent String           @default("INR")
  expiryRules        String?
  transferPartners   String?
  category           String
  logoUrl            String?
  color              String?
  isActive           Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  rewardAccounts     RewardAccount[]
  valuations         RewardValuation[]
  userCards          UserCard[]
}

model RewardAccount {
  id              String            @id @default(cuid())
  userId          String
  programId       String
  balance         Float             @default(0)
  estimatedValueINR Float           @default(0)
  lastSynced      DateTime          @default(now())
  expiryDate      DateTime?
  status          String            @default("active")
  tier            String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  program         RewardProgram     @relation(fields: [programId], references: [id], onDelete: Cascade)
  transactions    RewardTransaction[]
  valuations      RewardValuation[]

  @@unique([userId, programId])
}

model RewardTransaction {
  id              String         @id @default(cuid())
  accountId       String
  type            String
  points          Float
  valueINR        Float
  description     String
  transactionDate DateTime
  createdAt       DateTime       @default(now())
  account         RewardAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model RewardValuation {
  id                   String         @id @default(cuid())
  accountId            String
  programId            String
  pointsValued         Float
  inrValue             Float
  redemptionEfficiency Float
  valuedAt             DateTime       @default(now())
  account              RewardAccount  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  program              RewardProgram  @relation(fields: [programId], references: [id], onDelete: Cascade)
}

model Recommendation {
  id          String   @id @default(cuid())
  userId      String
  type        String
  title       String
  description String
  priority    String   @default("medium")
  actionUrl   String?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AgentExecution {
  id           String   @id @default(cuid())
  userId       String
  agentName    String
  workflowName String?
  status       String   @default("pending")
  input        String?
  output       String?
  durationMs   Int?
  executedAt   DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
